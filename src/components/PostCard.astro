---
import PostMeta from './PostMeta.astro';
import { readingTime } from '../lib/reading-time';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const href = `/posts/${post.id}`;
const rt = readingTime(post.body ?? '');
---

<article class="group relative py-5 border-b border-[var(--border)] last:border-0">
  <PostMeta pubDate={post.data.pubDate} readingTime={rt.label} tags={post.data.tags} compact />
  <h3 class="mt-2 font-serif text-xl md:text-[1.4rem] font-semibold text-[var(--fg)] leading-snug transition-colors">
    <a
      href={href}
      class="before:absolute before:inset-0 before:content-[''] group-hover:text-[var(--accent)]"
    >
      {post.data.title}
    </a>
  </h3>
  {
    post.data.description && (
      <p class="mt-2 text-[var(--fg-muted)] leading-relaxed line-clamp-2">
        {post.data.description}
      </p>
    )
  }
</article>
